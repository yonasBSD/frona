FROM rust:1.89-bookworm

# Install system deps: build tools, Python 3, Node 22
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential gfortran libopenblas-dev libclang-dev \
    python3 python3-pip python3-venv \
    curl \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Python data science packages
RUN pip install --no-cache-dir --break-system-packages \
    pandas numpy scipy matplotlib seaborn scikit-learn requests beautifulsoup4 reportlab

# Install cargo-watch
RUN cargo install cargo-watch

# Create non-root user and fix directory ownership
RUN groupadd -g 1000 frona && useradd -u 1000 -g frona -m -s /bin/bash frona
RUN mkdir -p /app /app/target /app/frontend/node_modules /app/data \
    && chown -R frona:frona /app /usr/local/cargo

USER frona
WORKDIR /app

# Pre-install frontend dependencies (layer cached unless package.json changes)
COPY --chown=frona:frona frontend/package.json frontend/package-lock.json* frontend/
RUN cd frontend && npm install

# Source is mounted via docker-compose volumes
CMD ["bash", "-c", "cargo watch -w engine/ -w Cargo.toml -w Cargo.lock --delay 3 -x 'run -p frona' & cd frontend && npm run dev & wait"]
