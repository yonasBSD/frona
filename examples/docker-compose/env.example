# Frona Environment Variables
# All settings below show their defaults (commented out).
# Uncomment and modify as needed.

# Authentication (REQUIRED)

FRONA_AUTH_ENCRYPTION_SECRET=change-me-to-a-random-secret
# FRONA_AUTH_ACCESS_TOKEN_EXPIRY_SECS=900        # 15 minutes
# FRONA_AUTH_REFRESH_TOKEN_EXPIRY_SECS=604800    # 7 days
# FRONA_AUTH_PRESIGN_EXPIRY_SECS=86400           # 24 hours

# Server

# FRONA_SERVER_PORT=3001
# FRONA_SERVER_STATIC_DIR=frontend/out
# FRONA_SERVER_ISSUER_URL=
# FRONA_SERVER_MAX_CONCURRENT_TASKS=10
# FRONA_SERVER_SANDBOX_DISABLED=false
# FRONA_SERVER_SANDBOX_MAX_AGENT_CPU_PCT=80.0
# FRONA_SERVER_SANDBOX_MAX_AGENT_MEMORY_PCT=80.0
# FRONA_SERVER_SANDBOX_MAX_TOTAL_CPU_PCT=90.0
# FRONA_SERVER_SANDBOX_MAX_TOTAL_MEMORY_PCT=90.0
# FRONA_SERVER_SANDBOX_TIMEOUT_SECS=0            # 0 = no timeout
# FRONA_SERVER_MAX_BODY_SIZE_BYTES=104857600     # 100 MB
# FRONA_SERVER_SHUTDOWN_TIMEOUT_SECS=60
# FRONA_SERVER_BASE_URL=https://your-domain.com
# FRONA_SERVER_BACKEND_URL=https://api.your-domain.com
# FRONA_SERVER_FRONTEND_URL=https://your-domain.com
# FRONA_SERVER_CORS_ORIGINS=https://your-domain.com

# SSO (OpenID Connect)

# FRONA_SSO_ENABLED=false
# FRONA_SSO_AUTHORITY=https://accounts.google.com
# FRONA_SSO_CLIENT_ID=your-client-id
# FRONA_SSO_CLIENT_SECRET=your-client-secret
# FRONA_SSO_SCOPES=email profile offline_access
# FRONA_SSO_ALLOW_UNKNOWN_EMAIL_VERIFICATION=false
# FRONA_SSO_CLIENT_CACHE_EXPIRATION=0
# FRONA_SSO_ONLY=false                           # if true, SSO is the only login method
# FRONA_SSO_SIGNUPS_MATCH_EMAIL=true

# Database

# FRONA_DATABASE_PATH=data/db

# Browser Automation
# These are set automatically via docker-compose environment section.

# FRONA_BROWSER_WS_URL=ws://browserless:3333
# FRONA_BROWSER_PROFILES_PATH=/profiles
# FRONA_BROWSER_CONNECTION_TIMEOUT_MS=30000

# Web Search
# SearXNG URL is set automatically via docker-compose environment section.

# FRONA_SEARCH_PROVIDER=searxng                  # or: tavily, brave
# FRONA_SEARCH_SEARXNG_BASE_URL=http://searxng:8080

# Storage

# FRONA_STORAGE_WORKSPACES_PATH=data/workspaces
# FRONA_STORAGE_FILES_PATH=data/files
# FRONA_STORAGE_SHARED_CONFIG_DIR=resources
# FRONA_STORAGE_SKILLS_DIR=data/skills
# FRONA_STORAGE_CACHE_DIR=data/system/cache

# Scheduler

# FRONA_SCHEDULER_SPACE_COMPACTION_SECS=3600     # 1 hour
# FRONA_SCHEDULER_MEMORY_COMPACTION_SECS=7200    # 2 hours
# FRONA_SCHEDULER_POLL_SECS=60

# Inference

# FRONA_INFERENCE_MAX_TOOL_TURNS=200
# FRONA_INFERENCE_DEFAULT_MAX_TOKENS=8192
# FRONA_INFERENCE_COMPACTION_TRIGGER_PCT=80
# FRONA_INFERENCE_HISTORY_TRUNCATION_PCT=90

# Voice (Twilio)

# FRONA_VOICE_PROVIDER=twilio
# FRONA_VOICE_TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# FRONA_VOICE_TWILIO_AUTH_TOKEN=your-auth-token
# FRONA_VOICE_TWILIO_FROM_NUMBER=+15551234567
# FRONA_VOICE_TWILIO_VOICE_ID=your-voice-id
# FRONA_VOICE_TWILIO_SPEECH_MODEL=your-speech-model
# FRONA_VOICE_CALLBACK_BASE_URL=https://your-public-url.com

# Vault (Password Manager Integration)

# FRONA_VAULT_ONEPASSWORD_SERVICE_ACCOUNT_TOKEN=your-token
# FRONA_VAULT_ONEPASSWORD_VAULT_ID=your-vault-id
# FRONA_VAULT_BITWARDEN_CLIENT_ID=your-client-id
# FRONA_VAULT_BITWARDEN_CLIENT_SECRET=your-client-secret
# FRONA_VAULT_BITWARDEN_MASTER_PASSWORD=your-password
# FRONA_VAULT_BITWARDEN_SERVER_URL=https://your-bitwarden.com
# FRONA_VAULT_HASHICORP_ADDRESS=https://vault.example.com
# FRONA_VAULT_HASHICORP_TOKEN=your-token
# FRONA_VAULT_HASHICORP_MOUNT=secret
# FRONA_VAULT_KEEPASS_PATH=/path/to/database.kdbx
# FRONA_VAULT_KEEPASS_PASSWORD=your-password
# FRONA_VAULT_KEEPER_APP_KEY=your-app-key

# Apps (Agent-Published Web Apps)

# FRONA_APP_PORT_RANGE_START=4000
# FRONA_APP_PORT_RANGE_END=4100
# FRONA_APP_HEALTH_CHECK_TIMEOUT_SECS=30
# FRONA_APP_MAX_RESTART_ATTEMPTS=2
# FRONA_APP_HIBERNATE_AFTER_SECS=259200          # 3 days

# Cache

# FRONA_CACHE_ENTITY_TTL_SECS=300                # 5 minutes
# FRONA_CACHE_ENTITY_MAX_CAPACITY=1000

# Logging

# FRONA_LOG_LEVEL=info                           # trace, debug, info, warn, error

# LLM Provider API Keys
# Uncomment the providers you want to use. At least one is required.
# Auto-discovery will detect these and configure providers automatically.

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...
# DEEPSEEK_API_KEY=sk-...
# GEMINI_API_KEY=...
# COHERE_API_KEY=...
# MISTRAL_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# TOGETHER_API_KEY=...
# XAI_API_KEY=xai-...
# HYPERBOLIC_API_KEY=...
# MOONSHOT_API_KEY=...
# MIRA_API_KEY=...
# GALADRIEL_API_KEY=...
# HUGGINGFACE_API_KEY=hf_...

# Self-Hosted LLM

# OLLAMA_API_BASE_URL=http://host.docker.internal:11434

# Search Provider API Keys (optional)
# These are alternatives to the bundled SearXNG instance.

# TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=BSA...
